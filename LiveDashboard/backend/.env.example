# ---- Server binding ----
HOST=0.0.0.0
PORT=8000
# Set RELOAD=1 for auto-reload during local development.
RELOAD=1

# ---- CORS ----
# Comma separated list of allowed origins. Use "*" for local development.
# In production set this to your deployed frontend origin.
CORS_ORIGINS=*

# ---- Static frontend (single unified service) ----
# Path to the compiled Angular build. When this folder exists FastAPI serves
# the SPA at "/". Leave as-is when running backend + frontend separately.
FRONTEND_DIST=../frontend/dist/live-dashboard/browser

# ---- Data providers ----
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_REST_URL=https://api.hyperliquid.xyz/info

# ---- Polling ----
# How often (seconds) HTTP based sources (e.g. yfinance) are polled.
POLL_INTERVAL_SECONDS=5
